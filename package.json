{
  "name": "spotify-stats",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "turbo run build",
    "dev:web": "pnpm --filter @spotify-stats/web dev",
    "dev:ingest": "pnpm --filter @spotify-stats/ingest dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "pnpm --filter @spotify-stats/db db:generate",
    "db:migrate": "pnpm --filter @spotify-stats/db db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
